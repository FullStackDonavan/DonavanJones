[Unit]
Description=donavanjones service
Documentation=https://donavanjones.com
After=network.target


[Service]
Restart=always
RestartSec=10
TimeoutSec=300
WorkingDirectory=/var/www/html/live
ExecStart=/usr/bin/bash -c 'node .output/server/index.mjs'

[Install]
WantedBy=multi-user.target

# /etc/systemd/system/donavanjones.service
